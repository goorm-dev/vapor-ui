# DeepL
DEEPL_API_KEY=your-deepl-api-key
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate
# glossary_id는 DeepL 대시보드 또는 POST /v2/glossaries 로 사전 생성 후 기입
# 미설정 시 glossary 없이 번역됨
DEEPL_GLOSSARY_ID=

# LLM via litellm proxy
LITELLM_BASE_URL=https://litellm.internal.goorm.io
LITELLM_API_KEY=your-litellm-api-key
LITELLM_MODEL=claude-sonnet-4-6
