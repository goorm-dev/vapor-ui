{
    "name": "figma-codegen-plugin",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "rimraf dist && mkdir -p dist && node build.mjs && cp manifest.json dist/",
        "clean": "rimraf dist node_modules .turbo",
        "dev": "node build.mjs --watch",
        "lint": "eslint ./src",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@figma/plugin-typings": "^1.125.0",
        "@repo/eslint-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "esbuild": "^0.28.0",
        "eslint": "catalog:",
        "typescript": "catalog:"
    }
}
