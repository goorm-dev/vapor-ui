{
    "name": "@vapor-ui/tokens",
    "version": "0.0.0-private",
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./manifest": {
            "types": "./dist/manifest.d.ts",
            "import": "./dist/manifest.js",
            "require": "./dist/manifest.cjs"
        },
        "./manifest.json": "./dist/manifest.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "pnpm run gen && tsup && pnpm run gen:json",
        "clean": "rimraf dist node_modules .turbo",
        "gen": "tsx scripts/build.ts --src-only",
        "gen:json": "tsx scripts/build.ts --dist-only",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@babel/parser": "^7.24.0",
        "@babel/types": "^7.24.0",
        "@types/node": "^22.19.20",
        "rimraf": "^6.1.3",
        "tsup": "^8.0.0",
        "tsx": "^4.7.0",
        "typescript": "catalog:"
    }
}
