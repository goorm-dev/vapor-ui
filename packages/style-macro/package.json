{
    "name": "@vapor-ui/style-macro",
    "version": "0.0.0",
    "description": "Build-time macro powering @vapor-ui/core's $style function.",
    "license": "MIT",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./unplugin": {
            "types": "./dist/unplugin.d.ts",
            "import": "./dist/unplugin.js",
            "require": "./dist/unplugin.cjs"
        },
        "./next": {
            "types": "./dist/next.d.ts",
            "import": "./dist/next.js",
            "require": "./dist/next.cjs"
        },
        "./turbopack-loader": {
            "types": "./dist/turbopack-loader.d.ts",
            "import": "./dist/turbopack-loader.js",
            "require": "./dist/turbopack-loader.cjs"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "bench": "vitest bench --run",
        "build": "tsup",
        "clean": "rimraf dist node_modules .turbo",
        "lint": "eslint ./src",
        "test": "vitest --run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@babel/code-frame": "^7.29.7",
        "@vapor-ui/tokens": "workspace:*",
        "csstype": "^3.2.3",
        "magic-string": "^0.30.21",
        "oxc-parser": "^0.138.0",
        "unplugin": "^3.3.0"
    },
    "devDependencies": {
        "@repo/eslint-config": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^11.1.6",
        "@types/babel__code-frame": "^7.27.0",
        "@types/node": "^20.19.43",
        "eslint": "catalog:",
        "rimraf": "^6.1.3",
        "rollup": "^4.62.2",
        "tsup": "^8.5.1",
        "typescript": "catalog:",
        "vite": "^7.3.6",
        "vitest": "^3.2.6"
    },
    "publishConfig": {
        "access": "public"
    }
}
