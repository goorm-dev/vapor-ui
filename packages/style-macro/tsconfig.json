{
    "extends": "@repo/typescript-config/base",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "target": "ES2022",
        "lib": ["ES2022"],
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": [
        "src/**/*.stories.tsx",
        "src/**/*.stories.ts",
        "src/**/*.test.ts",
        "src/**/*.test.tsx"
    ]
}
