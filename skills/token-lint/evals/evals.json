{
    "skill_name": "token-lint",
    "evals": [
        {
            "id": 1,
            "name": "all-clean-css",
            "prompt": "이 디렉터리의 디자인 토큰 사용을 검사해줘: /tmp/token-lint-eval/clean/",
            "expected_output": "전체 0건 typo. exit 0. '검사 완료' 메시지.",
            "files": [
                {
                    "path": "/tmp/token-lint-eval/clean/styles.css",
                    "content": ".btn { color: var(--vapor-color-foreground-primary-100); padding: var(--vapor-size-space-100); border-radius: var(--vapor-size-borderRadius-300); }"
                }
            ],
            "assertions": [
                {
                    "text": "exit code 0"
                },
                {
                    "text": "'검사 완료' 또는 '찾지 못했습니다' 메시지 포함"
                },
                {
                    "text": "어떤 --vapor- 변수도 typo로 신고하지 않음"
                }
            ]
        },
        {
            "id": 2,
            "name": "typo-with-close-suggestion",
            "prompt": "/token-lint /tmp/token-lint-eval/typos/",
            "expected_output": "최소 2건 typo 검출. 각 typo에 distance ≤ 2 후보 제시. exit 0 (typo 발견은 실패 아님 — SKILL.md 명시).",
            "files": [
                {
                    "path": "/tmp/token-lint-eval/typos/card.tsx",
                    "content": "export const Card = () => (<div style={{ color: 'var(--vapor-color-foregruond-primary-100)', padding: 'var(--vapor-size-spce-100)' }}>x</div>);"
                }
            ],
            "assertions": [
                {
                    "text": "exit code 0"
                },
                {
                    "text": "요약 줄에 '2건' 발견 명시"
                },
                {
                    "text": "--vapor-color-foregruond-primary-100 에 대해 --vapor-color-foreground-primary-100 추천"
                },
                {
                    "text": "--vapor-size-spce-100 에 대해 --vapor-size-space-100 추천"
                },
                {
                    "text": "각 typo에 file:line 정보 포함"
                }
            ]
        },
        {
            "id": 3,
            "name": "mixed-native-and-skip-dirs",
            "prompt": "이 프로젝트 lint해줘. /tmp/token-lint-eval/mixed/",
            "expected_output": "native --webkit-* 변수는 무시. node_modules 안 파일은 검사 제외. src/ 내 typo만 신고. exit 0 (typo 발견은 실패 아님).",
            "files": [
                {
                    "path": "/tmp/token-lint-eval/mixed/src/app.css",
                    "content": ".x { color: var(--vapor-color-background-canvas-100); -webkit-mask: var(--webkit-something); margin: var(--vapor-size-spaec-100); }"
                },
                {
                    "path": "/tmp/token-lint-eval/mixed/node_modules/lib/junk.css",
                    "content": ".y { color: var(--vapor-totally-fake-token); }"
                }
            ],
            "assertions": [
                {
                    "text": "exit code 0"
                },
                {
                    "text": "--vapor-size-spaec-100 typo로 신고됨"
                },
                {
                    "text": "--vapor-size-space-100 추천에 포함"
                },
                {
                    "text": "--webkit-something 무시됨 (스캔 결과에 등장 안 함)"
                },
                {
                    "text": "node_modules 안 --vapor-totally-fake-token 신고 안 됨"
                }
            ]
        },
        {
            "id": 4,
            "name": "string-literal-prefix-not-flagged",
            "prompt": "/token-lint /tmp/token-lint-eval/string-prefix/",
            "expected_output": "startsWith('var(--vapor-color-') 같은 미완성 prefix 문자열은 토큰 사용이 아님 — 검사 대상 아님. exit 0.",
            "files": [
                {
                    "path": "/tmp/token-lint-eval/string-prefix/util.ts",
                    "content": "export function isVaporToken(value: unknown): boolean {\n  return (\n    typeof value === 'string' &&\n    (value.startsWith('#') || value.startsWith('var(--vapor-color-'))\n  );\n}\n"
                }
            ],
            "assertions": [
                {
                    "text": "exit code 0"
                },
                {
                    "text": "'검사 완료' 또는 '찾지 못했습니다' 메시지 포함"
                },
                {
                    "text": "--vapor-color- 를 typo로 신고하지 않음"
                }
            ]
        }
    ]
}
