{
    "name": "@vapor-ui/ts-api-extractor",
    "version": "0.0.1",
    "private": true,
    "description": "TypeScript AST-based API extractor for documentation generation",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "ts-api-extractor": "./dist/cli/index.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "lint": "eslint ./src",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:run": "vitest run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "glob": "^10.5.0",
        "meow": "^14.1.0",
        "ts-morph": "^22.0.0"
    },
    "devDependencies": {
        "@repo/eslint-config": "workspace:*",
        "@types/node": "^20.19.43",
        "@vitest/coverage-v8": "^3.2.7",
        "eslint": "^9.39.4",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "catalog:",
        "vitest": "^3.2.7"
    },
    "peerDependencies": {
        "typescript": ">=5.9.3"
    },
    "engines": {
        "node": ">=20.20.2"
    }
}
