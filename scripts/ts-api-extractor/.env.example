# DeepL Translation API
DEEPL_API_KEY=your-deepl-api-key-here
# Optional: override default endpoint (https://api-free.deepl.com/v2/translate)
# Use https://api.deepl.com/v2/translate for Pro plan
DEEPL_ENDPOINT=

# Optional: pre-registered DeepL Glossary ID for domain term locking
# Create via DeepL API and paste the ID here
DEEPL_GLOSSARY_ID=

# LiteLLM Proxy (required for LLM MQM evaluation and post-editing)
LITELLM_API_KEY=your-litellm-api-key-here
LITELLM_BASE_URL=
